# Med-X — local environment template
# Copy to .env.local and fill in the real values. .env.local is gitignored.

# Supabase API base URL — must be the URL the BROWSER will hit.
# Local dev: relative path /__sb__ (proxied via Vite dev server to the prod nginx vhost).
# Production: same path under the prod nginx vhost (3040 today, 3030 after pm2 swap).
VITE_SUPABASE_URL=/__sb__

# Browser-safe publishable key. Cannot bypass RLS.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Absolute Supabase URL used by the SSR server (Node has no window.location).
# Local dev: hit the prod nginx vhost. Production: http://127.0.0.1:54321.
VITE_SUPABASE_SSR_URL=https://med-ix.ru/__sb__
